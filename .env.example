# =====================================================
# FRONTEND URLS
# =====================================================
# IMPORTANT: Update these URLs based on your environment
# Local Development: http://localhost:3000
# Production: https://www.lubist.com (or your production domain)
FRONTEND_URL=""  # Main customer/user frontend URL (used for password reset, email links, etc.)
ADMIN_PANEL_URL=""  # Admin panel URL
VENDOR_PORTAL_URL=""  # Vendor portal URL (can be subdomain of FRONTEND_URL)
RM_PORTAL_URL=""  # RM portal URL (can be subdomain of FRONTEND_URL)



# =====================================================
# LOGGING
# =====================================================
LOG_LEVEL=""  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=""

# =====================================================
# OTP SERVICE (MESSAGECENTRAL)
# =====================================================
# Used for phone-based OTP authentication
MESSAGECENTRAL_CUSTOMER_ID=""  # Your MessageCentral customer ID (e.g., C-7068A31773FC4D2)
MESSAGECENTRAL_KEY=""  # Your MessageCentral API key (base64 encoded)
MESSAGECENTRAL_EMAIL=""  # Your registered email with MessageCentral
MESSAGECENTRAL_BASE_URL="https://cpaas.messagecentral.com"
MESSAGECENTRAL_DEFAULT_COUNTRY_CODE="91"  # India country code (default)
MESSAGECENTRAL_OTP_LENGTH=6
MESSAGECENTRAL_OTP_EXPIRY_SECONDS=300  # 5 minutes

# =====================================================
# CLOUDINARY SETTINGS
# =====================================================
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CAREER_CLOUDINARY_UPLOAD_TYPE="private"  # private | public
CAREER_CLOUDINARY_SIGNED_URL_TTL=3600
