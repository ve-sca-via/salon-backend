# =====================================================
# ENVIRONMENT CONFIGURATION
# IMPORTANT: All keys below are REQUIRED. No defaults are provided.
# Copy this file to .env and fill in all values explicitly.
# =====================================================

# Application Settings
APP_NAME=""
APP_VERSION=""
APP_DESCRIPTION=""
ENVIRONMENT=""  # development, staging, production
DEBUG=""  # true or false
API_PREFIX=""

# Server Configuration
HOST=""
PORT=""
WORKERS=""
TOKEN_CLEANUP_INTERVAL_SECONDS=""  # seconds
BACKGROUND_SHUTDOWN_TIMEOUT_SECONDS=""  # seconds (float)

# CORS Settings (comma-separated origins)
ALLOWED_ORIGINS=""
ALLOWED_HOSTS=""  # comma-separated list of allowed hosts (e.g., localhost,example.com)
# =====================================================
# SUPABASE CONFIGURATION
# =====================================================
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Database (Supabase PostgreSQL)
DATABASE_URL=""

# =====================================================
# JWT & AUTHENTICATION
# =====================================================
JWT_SECRET_KEY=""  # Must be at least 32 characters
JWT_ALGORITHM=""
ACCESS_TOKEN_EXPIRE_MINUTES=""
REFRESH_TOKEN_EXPIRE_DAYS=""

# =====================================================
# PAYMENT GATEWAY (RAZORPAY)
# =====================================================
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# =====================================================
# EMAIL CONFIGURATION
# =====================================================
EMAIL_FROM=""
EMAIL_FROM_NAME=""
ADMIN_EMAIL=""

# SMTP Settings
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_TLS=""  # true or false
SMTP_SSL=""  # true or false

# =====================================================
# FRONTEND URLS
# =====================================================
FRONTEND_URL=""
ADMIN_PANEL_URL=""
VENDOR_PORTAL_URL=""
RM_PORTAL_URL=""

# =====================================================
# LOGGING
# =====================================================
LOG_LEVEL=""  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=""

# =====================================================
# OTP SERVICE (MESSAGECENTRAL)
# =====================================================
MESSAGECENTRAL_CUSTOMER_ID=""
MESSAGECENTRAL_KEY=""
MESSAGECENTRAL_EMAIL=""
MESSAGECENTRAL_BASE_URL=""
MESSAGECENTRAL_DEFAULT_COUNTRY_CODE=""
MESSAGECENTRAL_OTP_LENGTH=""
MESSAGECENTRAL_OTP_EXPIRY_SECONDS=""

# =====================================================
# CLOUDINARY SETTINGS
# =====================================================
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CAREER_CLOUDINARY_UPLOAD_TYPE=""  # private or public
CAREER_CLOUDINARY_SIGNED_URL_TTL=""  # seconds
